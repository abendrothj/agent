{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Staged Autonomy v9.3 — Vault + Shadow + Watchdog gRPC metrics and GPU telemetry",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Vault — Request Throughput",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(vault_grpc_requests_total[1m])",
          "legendFormat": "{{method}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Vault gRPC Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "p95"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(vault_grpc_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 {{method}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(vault_grpc_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 {{method}}",
          "refId": "B"
        }
      ],
      "title": "Vault gRPC Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "title": "Shadow — Validation Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(shadow_grpc_requests_total[1m])",
          "legendFormat": "{{method}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Shadow gRPC Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(shadow_grpc_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 {{method}}",
          "refId": "A"
        }
      ],
      "title": "Shadow Latency p99",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Watchdog — GPU Telemetry & Rollbacks",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "celsius",
          "min": 0, "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 17 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        { "expr": "watchdog_gpu_temp_celsius", "legendFormat": "GPU Temp", "refId": "A" }
      ],
      "title": "GPU Temperature (°C)",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 512 },
              { "color": "green", "value": 1024 }
            ]
          },
          "unit": "mbytes",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 17 },
      "id": 6,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        { "expr": "watchdog_gpu_memory_available_mb", "legendFormat": "VRAM Available", "refId": "A" }
      ],
      "title": "GPU VRAM Available (MB)",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "targets": [
        { "expr": "watchdog_latency_p99_ms", "legendFormat": "Latency P99", "refId": "A" }
      ],
      "title": "Muscle Inference Latency P99 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "id": 8,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "increase(watchdog_rollbacks_total[1h])",
          "legendFormat": "Rollbacks /1h",
          "refId": "A"
        },
        {
          "expr": "rate(watchdog_metrics_reports_total[5m])",
          "legendFormat": "Metrics reports/s — {{outcome}}",
          "refId": "B"
        }
      ],
      "title": "Watchdog Events",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["staged-autonomy", "grpc", "gpu"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Staged Autonomy v9.3",
  "uid": "staged-autonomy-v93",
  "version": 1
}
