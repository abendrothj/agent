# Pi environment variables — copy to .env and fill in real values
# Used by: deployments/pi/docker-compose.yml

# ── Database passwords ────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
SHADOW_DB_PASSWORD=changeme
WATCHDOG_DB_PASSWORD=changeme
SANDBOX_DB_PASSWORD=changeme

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme

# ── Observability ─────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme

# ── Win11 Muscle IP on your LAN ───────────────────────────────────
# Run `ipconfig` on Win11 and paste the IP here
MUSCLE_HOST=192.168.1.XXX

# ── mTLS certificates ─────────────────────────────────────────────
# Certificates are mounted read-only from /opt/teammate-vault/certs/
# Install them per PI_SETUP.md before starting services:
#
#   sudo install -m 600 client.crt /opt/teammate-vault/certs/
#   sudo install -m 600 client.key /opt/teammate-vault/certs/
#   sudo install -m 600 muscle.crt /opt/teammate-vault/certs/
#
# The CERT_FILE/KEY_FILE/CA_CERT env vars are set inside docker-compose.yml
# already — no need to set them here.

# ── OpenAI (needed for graphrag index rebuilds only) ──────────────
# Leave blank if not running graphrag indexing yet.
OPENAI_API_KEY=
