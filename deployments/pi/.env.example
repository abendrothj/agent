# Pi environment variables — copy to .env and fill in real values
# Used by: deployments/pi/docker-compose.yml

# ── Database passwords ────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
SHADOW_DB_PASSWORD=changeme
WATCHDOG_DB_PASSWORD=changeme
SANDBOX_DB_PASSWORD=changeme

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme

# ── Observability ─────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme

# ── Win11 Muscle IP on your LAN ───────────────────────────────────
# Run `ipconfig` on Win11 and paste the IP here
MUSCLE_HOST=192.168.1.XXX

# ── HTTP API Gateway ──────────────────────────────────────────────
# Optional: set to require X-API-Key header on all requests
# Leave blank to disable authentication (LAN-only deployments)
API_KEY=

# ── Slack Integration ─────────────────────────────────────────────
# From: Slack App settings → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=

# ── Cloudflare Tunnel ─────────────────────────────────────────────
# Named tunnel (stable public URL, recommended for production):
#   1. Run: cloudflared tunnel login   (on the Pi, once)
#   2. Run: cloudflared tunnel create  teammate-agent
#   3. Paste the token here
# Quick tunnel (random URL, good for testing):
#   Leave blank — URL prints in: docker logs pi_cloudflared | grep trycloudflare
CLOUDFLARE_TUNNEL_TOKEN=

# ── Agent Git Identity ────────────────────────────────────────────
# Create a dedicated GitHub account for the agent:
#   1. Sign up at github.com  (e.g. "your-org-agent")
#   2. Generate a PAT: Settings → Developer settings → Fine-grained tokens
#      Scopes needed: Contents (read+write), Pull Requests (read+write),
#                     Issues (read), Metadata (read), Fork (write)
#   3. Fill in below
# On first Vault container start the agent generates an RSA-4096 SSH key.
# Its public key is printed in: docker logs pi_vault | grep "SSH public key"
# Add that public key to the agent GitHub account → Settings → SSH keys.
GITHUB_TOKEN=
GITHUB_USERNAME=teammate-agent
GITHUB_EMAIL=agent@teammate.local
AGENT_GIT_NAME=teammate-agent
# Your own repo in "owner/repo" format — enables self-modification PRs
AGENT_REPO=

# How often the autonomy loop wakes (seconds). Default 7200 = 2 hours.
AUTONOMY_INTERVAL_SECONDS=7200

# ── MCP (Peripheral Nervous System / Sensory Organs) ─────────────────────────
# MCP provides sensory context to the Vault before risk classification fires.
# Biology: MCP servers = sensory receptors; MCPContextProvider = thalamus;
#          node_sense_context = primary sensory cortex.
# Cost: completely free — all transport is local stdio, no API calls.

# Set to "false" to disable all MCP context gathering (senses offline).
MCP_ENABLED=true

# Absolute path mounted into the Vault container that points to the codebase.
# node_sense_context reads relevant files from here to enrich classification.
MCP_WORKSPACE_PATH=/app

# Hard timeout for the thalamic gating window (seconds).
# If sensory signals don't arrive in time, cognition proceeds without them.
MCP_TIMEOUT_SECONDS=2.0
