# Pi environment variables — copy to .env and fill in real values
# Used by: deployments/pi/docker-compose.yml

# ── Database passwords ────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
SHADOW_DB_PASSWORD=changeme
WATCHDOG_DB_PASSWORD=changeme
SANDBOX_DB_PASSWORD=changeme

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme

# ── Observability ─────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme

# ── Win11 Muscle IP on your LAN ───────────────────────────────────
# Run `ipconfig` on Win11 and paste the IP here
MUSCLE_HOST=192.168.1.XXX
