# Win11 environment variables — copy to .env and fill in real values
# Used by: deployments/win11/docker-compose.yml

# ── Container image source (GHCR or local) ───────────────────────
# GHCR example for this repo (abendrothj/agent):
# MUSCLE_IMAGE=ghcr.io/abendrothj/agent-muscle:latest
# Local fallback: MUSCLE_IMAGE=win11-muscle:latest
MUSCLE_IMAGE=win11-muscle:latest

# ── Pi Vault address on your LAN ──────────────────────────────────
# Run `hostname -I` on Pi and paste the IP here
VAULT_API_URL=192.168.1.XXX:50051

# ── HuggingFace model ─────────────────────────────────────────────
HF_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct
# Options: "none", "4bit", "8bit"  (4bit recommended for 8GB VRAM)
HF_QUANTIZE=none
HF_MAX_TOKENS=1024
HF_TEMPERATURE=0.7

# ── mTLS certificates ─────────────────────────────────────────────
# Place these files in deployments/win11/certs/ (beside this file):
#   muscle.crt  — Win11's TLS certificate (identity)
#   muscle.key  — Win11's private key  (keep secret, never copy to Pi)
#   client.crt  — Pi's certificate     (used to verify the Vault)
#
# See WIN11_SETUP.md for generation + transfer instructions.
# The CERT_FILE/KEY_FILE/CA_CERT vars are set in docker-compose.yml already.

# ── HuggingFace token (only needed for gated models) ─────────────
HF_TOKEN=
